# ── Database backend ──────────────────────────────────────────────────────────
# Set to "databricks" to use Databricks Delta Lake.
# Any other value (or omit entirely) uses the in-memory store.
DATABASE_BACKEND=databricks

# ── Databricks connection ─────────────────────────────────────────────────────
# Found in your Databricks workspace under:
#   SQL Warehouses → <your warehouse> → Connection details

# Server hostname, e.g. adb-1234567890123456.7.azuredatabricks.net
DATABRICKS_SERVER_HOSTNAME=<your-workspace>.azuredatabricks.net

# SQL Warehouse HTTP path, e.g. /sql/1.0/warehouses/abc123def456
DATABRICKS_HTTP_PATH=/sql/1.0/warehouses/<warehouse-id>

# Personal Access Token (Settings → Developer → Access tokens → Generate)
# Or use a Service Principal OAuth token.
DATABRICKS_TOKEN=dapi0000000000000000000000000000000000

# ── Unity Catalog (optional) ──────────────────────────────────────────────────
# Defaults to hive_metastore / default if not set.
# DATABRICKS_CATALOG=main
# DATABRICKS_SCHEMA=agent_dashboard
